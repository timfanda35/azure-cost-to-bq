# ── Azure Blob (source) ───────────────────────────────────────────────────────
AZURE_STORAGE_ACCOUNT_URL=https://myacct.blob.core.windows.net   # Required
AZURE_STORAGE_CONTAINER=exports                                  # Required: container the exports write to
AZURE_ROOT_FOLDER_PATH=azure-cost/ea                             # Optional: rootFolderPath configured on the exports

# Private endpoint override (optional): when the storage account is behind a
# private endpoint, point the blob client at it. SP token audience is unchanged.
# AZURE_BLOB_ENDPOINT_URL=https://myacct.privatelink.blob.core.windows.net

# Blob auth — pick ONE. Priority: connection string > SAS token > service principal.
# Service principal (recommended; needs Storage Blob Data Reader on the account):
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
# AZURE_STORAGE_SAS_TOKEN=?sv=...&sig=...
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...

# ── Exports to sync (set the name of each export you created in Azure) ─────────
# Configure at least one. Each export's name is the path segment in blob storage.
# Cost and usage details (actual)
# Cost and usage details (amortized)
# Cost and usage details (FOCUS 1.2-preview)
EXPORT_NAME=ea-actual-daily
BILLING_SCHEMA=actual  # actual | amortized | focus

# ── GCS staging ───────────────────────────────────────────────────────────────
GCS_BUCKET=my-gcs-staging-bucket            # Required
GCS_DESTINATION_PREFIX=billing/azure        # Optional: path prefix in GCS

# ── BigQuery destination ──────────────────────────────────────────────────────
BQ_PROJECT_ID=my-gcp-project                # Required
BQ_DATASET_ID=billing                       # Required
BQ_TABLE_ID=azure_cost_actual                  # Optional (default shown)
# BQ_CMEK_KEY_NAME=projects/p/locations/us/keyRings/r/cryptoKeys/k   # Optional CMEK
# BQ_ENFORCE_SCHEMA=false   # Optional: true = apply explicit JSON schema instead of parquet's embedded schema

# ── Sync window / runtime ─────────────────────────────────────────────────────
PREVIOUS_MONTHS=1           # Optional: also sync N previous months (default 1 → current + previous)
# REPORT=focus              # Optional: limit a run to one report type (actual|amortized|focus)
# PARTITION=2026-05         # Optional: ad-hoc single billing period (overridden by --partition)

# ── Server (optional) ─────────────────────────────────────────────────────────
PORT=8080
LOG_LEVEL=INFO
